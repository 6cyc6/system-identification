<mujoco model="pushT scene">
  <!--
    Self-contained scene for PushT-MJX.
    Robot: Franka Panda (7-DOF) with pusher tip (no gripper fingers).
    Objects: T-shape (freejoint), table, goal mocap marker.
    Mesh assets are loaded from the panda_assets dict in pushT_env_mjx.py.
  -->
  <compiler angle="radian" autolimits="true"/>

  <option
    timestep="0.00833333"
    iterations="8"
    ls_iterations="8"
    integrator="implicitfast">
    <flag eulerdamp="disable"/>
  </option>

  <default>
    <default class="panda">
      <joint range="-2.8973 2.8973" armature="0.1" damping="1"/>
      <default class="panda/visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="panda/collision">
        <geom type="mesh" group="3" contype="1" conaffinity="1"/>
      </default>
    </default>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="0.8 0.8 0.8" width="256" height="256"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.8 0.8 0.8" rgb2="0.7 0.7 0.7"
      markrgb="0 0 0" width="256" height="256"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="4 4" reflectance="0.1"/>
    <material name="table_mat" rgba="0.7 0.5 0.3 1"/>
    <material name="tshape_mat" rgba="0.2 0.4 0.8 1"/>
    <material name="goal_mat" rgba="0.0 1.0 0.0 0.35"/>
    <material name="white" rgba="1 1 1 1"/>
    <material name="off_white" rgba="0.901961 0.921569 0.929412 1"/>
    <material name="dark_grey" rgba="0.25 0.25 0.25 1"/>
    <material name="green" rgba="0 1 0 1"/>
    <material name="light_blue" rgba="0.039216 0.541176 0.780392 1"/>
    <material name="pusher_mat" rgba="0.9 0.5 0.1 1"/>

    <!-- Robot collision meshes -->
    <mesh name="link0_c" file="link0.stl"/>
    <mesh name="link1_c" file="link1.stl"/>
    <mesh name="link2_c" file="link2.stl"/>
    <mesh name="link3_c" file="link3.stl"/>
    <mesh name="link4_c" file="link4.stl"/>
    <mesh name="link5_c0" file="link5_collision_0.obj"/>
    <mesh name="link5_c1" file="link5_collision_1.obj"/>
    <mesh name="link5_c2" file="link5_collision_2.obj"/>
    <mesh name="link6_c" file="link6.stl"/>
    <mesh name="link7_c" file="link7.stl"/>

    <!-- Robot visual meshes -->
    <mesh file="link0_0.obj"/>
    <mesh file="link0_1.obj"/>
    <mesh file="link0_2.obj"/>
    <mesh file="link0_3.obj"/>
    <mesh file="link0_4.obj"/>
    <mesh file="link0_5.obj"/>
    <mesh file="link0_7.obj"/>
    <mesh file="link0_8.obj"/>
    <mesh file="link0_9.obj"/>
    <mesh file="link0_10.obj"/>
    <mesh file="link0_11.obj"/>
    <mesh file="link1.obj"/>
    <mesh file="link2.obj"/>
    <mesh file="link3_0.obj"/>
    <mesh file="link3_1.obj"/>
    <mesh file="link3_2.obj"/>
    <mesh file="link3_3.obj"/>
    <mesh file="link4_0.obj"/>
    <mesh file="link4_1.obj"/>
    <mesh file="link4_2.obj"/>
    <mesh file="link4_3.obj"/>
    <mesh file="link5_0.obj"/>
    <mesh file="link5_1.obj"/>
    <mesh file="link5_2.obj"/>
    <mesh file="link6_0.obj"/>
    <mesh file="link6_1.obj"/>
    <mesh file="link6_2.obj"/>
    <mesh file="link6_3.obj"/>
    <mesh file="link6_4.obj"/>
    <mesh file="link6_5.obj"/>
    <mesh file="link6_6.obj"/>
    <mesh file="link6_7.obj"/>
    <mesh file="link6_8.obj"/>
    <mesh file="link6_9.obj"/>
    <mesh file="link6_10.obj"/>
    <mesh file="link6_11.obj"/>
    <mesh file="link6_12.obj"/>
    <mesh file="link6_13.obj"/>
    <mesh file="link6_14.obj"/>
    <mesh file="link6_15.obj"/>
    <mesh file="link6_16.obj"/>
    <mesh file="link7_0.obj"/>
    <mesh file="link7_1.obj"/>
    <mesh file="link7_2.obj"/>
    <mesh file="link7_3.obj"/>
    <mesh file="link7_4.obj"/>
    <mesh file="link7_5.obj"/>
    <mesh file="link7_6.obj"/>
    <mesh file="link7_7.obj"/>

    <!-- T-shape object mesh -->
    <mesh name="tshape_mesh" file="t_shape.stl" scale="1 1 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1" directional="true" diffuse="0.9 0.9 0.9"/>
    <light pos="1 0 2" dir="-0.5 0 -1" directional="true" diffuse="0.4 0.4 0.4"/>
    <geom name="floor" size="2 2 0.05" type="plane" material="groundplane" contype="1" conaffinity="1"/>

    <!-- Table: 1.5m x 2.0m x 0.1m, top surface at z=0.1 -->
    <geom name="table" type="box" pos="0 0 0.05" size="0.75 1.0 0.05" material="table_mat"
      contype="1" conaffinity="1" friction="1.0 0.03 0.001"/>

    <!-- T-shape object (freejoint). Resting height: table top (0.1) + object half-height (~0.021) = 0.121 -->
    <body name="tshape" pos="0.03 0 0.121">
      <freejoint name="tshape_joint"/>
      <inertial mass="0.8" pos="0 0 0" diaginertia="0.0015 0.0015 0.0008"/>
      <geom name="tshape_col" type="mesh" mesh="tshape_mesh" material="tshape_mat"
        contype="2" conaffinity="1" friction="1.0 0.03 0.001"
        solref="0.01 1" solimp="0.9 0.95 0.001"/>
    </body>

    <!-- Goal marker (mocap): visualises the target pose for the T-shape -->
    <body name="goal_marker" mocap="true" pos="0.03 0 0.121">
      <geom name="goal_geom" type="mesh" mesh="tshape_mesh" material="goal_mat"
        contype="0" conaffinity="0"/>
    </body>

    <!-- Franka Panda robot base at (-0.5, 0, 0.1) — matches IsaacLab robot.init_state.pos -->
    <body name="link0" pos="-0.5 0 0.1" childclass="panda">
      <inertial mass="0.629769" pos="-0.041018 -0.00014 0.049974"
        fullinertia="0.00315 0.00388 0.004285 8.2904e-7 0.00015 8.2299e-6"/>
      <geom mesh="link0_0" material="off_white" class="panda/visual"/>
      <geom mesh="link0_1" material="dark_grey" class="panda/visual"/>
      <geom mesh="link0_2" material="off_white" class="panda/visual"/>
      <geom mesh="link0_3" material="dark_grey" class="panda/visual"/>
      <geom mesh="link0_4" material="off_white" class="panda/visual"/>
      <geom mesh="link0_5" material="dark_grey" class="panda/visual"/>
      <geom mesh="link0_7" material="white" class="panda/visual"/>
      <geom mesh="link0_8" material="white" class="panda/visual"/>
      <geom mesh="link0_9" material="dark_grey" class="panda/visual"/>
      <geom mesh="link0_10" material="off_white" class="panda/visual"/>
      <geom mesh="link0_11" material="white" class="panda/visual"/>
      <geom mesh="link0_c" class="panda/collision"/>

      <body name="link1" pos="0 0 0.333">
        <inertial mass="4.970684" pos="0.003875 0.002081 -0.04762"
          fullinertia="0.70337 0.70661 0.0091170 -0.00013900 0.0067720 0.019169"/>
        <joint name="joint1" class="panda"/>
        <geom material="white" mesh="link1" class="panda/visual"/>
        <geom mesh="link1_c" class="panda/collision"/>

        <body name="link2" quat="1 -1 0 0">
          <inertial mass="0.646926" pos="-0.003141 -0.02872 0.003495"
            fullinertia="0.0079620 2.8110e-2 2.5995e-2 -3.925e-3 1.0254e-2 7.04e-4"/>
          <joint name="joint2" class="panda" range="-1.7628 1.7628"/>
          <geom material="white" mesh="link2" class="panda/visual"/>
          <geom mesh="link2_c" class="panda/collision"/>

          <body name="link3" pos="0 -0.316 0" quat="1 1 0 0">
            <inertial mass="3.228604" pos="2.7518e-2 3.9252e-2 -6.6502e-2"
              fullinertia="3.7242e-2 3.6155e-2 1.083e-2 -4.761e-3 -1.1396e-2 -1.2805e-2"/>
            <joint name="joint3" class="panda"/>
            <geom mesh="link3_0" material="white" class="panda/visual"/>
            <geom mesh="link3_1" material="white" class="panda/visual"/>
            <geom mesh="link3_2" material="white" class="panda/visual"/>
            <geom mesh="link3_3" material="dark_grey" class="panda/visual"/>
            <geom mesh="link3_c" class="panda/collision"/>

            <body name="link4" pos="0.0825 0 0" quat="1 1 0 0">
              <inertial mass="3.587895" pos="-5.317e-2 1.04419e-1 2.7454e-2"
                fullinertia="2.5853e-2 1.9552e-2 2.8323e-2 7.796e-3 -1.332e-3 8.641e-3"/>
              <joint name="joint4" class="panda" range="-3.0718 -0.0698"/>
              <geom mesh="link4_0" material="white" class="panda/visual"/>
              <geom mesh="link4_1" material="white" class="panda/visual"/>
              <geom mesh="link4_2" material="dark_grey" class="panda/visual"/>
              <geom mesh="link4_3" material="white" class="panda/visual"/>
              <geom mesh="link4_c" class="panda/collision"/>

              <body name="link5" pos="-0.0825 0.384 0" quat="1 -1 0 0">
                <inertial mass="1.225946" pos="-1.1953e-2 4.1065e-2 -3.8437e-2"
                  fullinertia="3.5549e-2 2.9474e-2 8.627e-3 -2.117e-3 -4.037e-3 2.29e-4"/>
                <joint name="joint5" class="panda"/>
                <geom mesh="link5_0" material="dark_grey" class="panda/visual"/>
                <geom mesh="link5_1" material="white" class="panda/visual"/>
                <geom mesh="link5_2" material="white" class="panda/visual"/>
                <geom mesh="link5_c0" class="panda/collision"/>
                <geom mesh="link5_c1" class="panda/collision"/>
                <geom mesh="link5_c2" class="panda/collision"/>

                <body name="link6" quat="1 1 0 0">
                  <inertial mass="1.666555" pos="6.0149e-2 -1.4117e-2 -1.0517e-2"
                    fullinertia="1.964e-3 4.354e-3 5.433e-3 1.09e-4 -1.158e-3 3.41e-4"/>
                  <joint name="joint6" class="panda" range="-0.0175 3.7525"/>
                  <geom mesh="link6_0" material="off_white" class="panda/visual"/>
                  <geom mesh="link6_1" material="white" class="panda/visual"/>
                  <geom mesh="link6_2" material="dark_grey" class="panda/visual"/>
                  <geom mesh="link6_3" material="white" class="panda/visual"/>
                  <geom mesh="link6_4" material="white" class="panda/visual"/>
                  <geom mesh="link6_5" material="white" class="panda/visual"/>
                  <geom mesh="link6_6" material="white" class="panda/visual"/>
                  <geom mesh="link6_7" material="light_blue" class="panda/visual"/>
                  <geom mesh="link6_8" material="light_blue" class="panda/visual"/>
                  <geom mesh="link6_9" material="dark_grey" class="panda/visual"/>
                  <geom mesh="link6_10" material="dark_grey" class="panda/visual"/>
                  <geom mesh="link6_11" material="white" class="panda/visual"/>
                  <geom mesh="link6_12" material="green" class="panda/visual"/>
                  <geom mesh="link6_13" material="white" class="panda/visual"/>
                  <geom mesh="link6_14" material="dark_grey" class="panda/visual"/>
                  <geom mesh="link6_15" material="dark_grey" class="panda/visual"/>
                  <geom mesh="link6_16" material="white" class="panda/visual"/>
                  <geom mesh="link6_c" class="panda/collision"/>

                  <body name="link7" pos="0.088 0 0" quat="1 1 0 0">
                    <inertial mass="7.35522e-01" pos="1.0517e-2 -4.252e-3 6.1597e-2"
                      fullinertia="1.2516e-2 1.0027e-2 4.815e-3 -4.28e-4 -1.196e-3 -7.41e-4"/>
                    <joint name="joint7" class="panda"/>
                    <geom mesh="link7_0" material="white" class="panda/visual"/>
                    <geom mesh="link7_1" material="dark_grey" class="panda/visual"/>
                    <geom mesh="link7_2" material="dark_grey" class="panda/visual"/>
                    <geom mesh="link7_3" material="dark_grey" class="panda/visual"/>
                    <geom mesh="link7_4" material="dark_grey" class="panda/visual"/>
                    <geom mesh="link7_5" material="dark_grey" class="panda/visual"/>
                    <geom mesh="link7_6" material="dark_grey" class="panda/visual"/>
                    <geom mesh="link7_7" material="white" class="panda/visual"/>
                    <geom mesh="link7_c" class="panda/collision"/>

                    <!-- EE flange body (fr3_link8 equivalent): 107mm beyond link7 -->
                    <body name="ee_flange" pos="0 0 0.107" quat="0.9238795 0 0 -0.3826834">
                      <inertial mass="0.10" pos="0 0 0.05" diaginertia="1e-4 1e-4 5e-5"/>

                      <!-- Pusher rod: capsule along z-axis (MJX supports capsule-box) -->
                      <geom name="pusher_rod" type="capsule" pos="0 0 0.075"
                        size="0.018 0.075" material="pusher_mat"
                        contype="1" conaffinity="1" friction="0.8 0.02 0.001"/>

                      <!-- Pusher tip sphere for better contact -->
                      <geom name="pusher_tip_geom" type="sphere" pos="0 0 0.155"
                        size="0.022" material="pusher_mat"
                        contype="1" conaffinity="1" friction="0.8 0.02 0.001"/>

                      <!-- Site at the EE flange origin (used for ee_pos observation) -->
                      <site name="ee_site" pos="0 0 0" size="0.01" rgba="1 0 0 1"/>

                      <!-- Site at pusher tip (175mm from flange, matches IsaacLab d=0.175) -->
                      <site name="fingertip_site" pos="0 0 0.175" size="0.008" rgba="1 0.5 0 1"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!--
    Position actuators with PD-like gains matching IsaacLab ImplicitActuator:
      stiffness (kp) = 400 for all joints
      damping (kv) = 40 for all joints

    For joints 1-4 (effort_limit=87), joints 5-7 (effort_limit=12).
    gainprm = kp, biasprm = (0, -kp, -kv) → force = kp*(ctrl-q) - kv*qdot
  -->
  <actuator>
    <general name="actuator1" joint="joint1"
      gainprm="400" biasprm="0 -400 -40" forcerange="-87 87"
      ctrlrange="-2.9671 2.9671"/>
    <general name="actuator2" joint="joint2"
      gainprm="400" biasprm="0 -400 -40" forcerange="-87 87"
      ctrlrange="-1.8326 1.8326"/>
    <general name="actuator3" joint="joint3"
      gainprm="400" biasprm="0 -400 -40" forcerange="-87 87"
      ctrlrange="-2.9671 2.9671"/>
    <general name="actuator4" joint="joint4"
      gainprm="400" biasprm="0 -400 -40" forcerange="-87 87"
      ctrlrange="-3.1416 0.0873"/>
    <general name="actuator5" joint="joint5"
      gainprm="400" biasprm="0 -400 -40" forcerange="-12 12"
      ctrlrange="-2.9671 2.9671"/>
    <general name="actuator6" joint="joint6"
      gainprm="400" biasprm="0 -400 -40" forcerange="-12 12"
      ctrlrange="-0.0873 3.8223"/>
    <general name="actuator7" joint="joint7"
      gainprm="400" biasprm="0 -400 -40" forcerange="-12 12"
      ctrlrange="-2.9671 2.9671"/>
  </actuator>

  <!--
    Keyframe:
      qpos = [joint1..7 (7), tshape_freejoint xyz+quat (7)] = 14 values
      ctrl = [actuator1..7] = joint targets = same as joint qpos
    IsaacLab init joints: [0.6127, 0.1663, 0.1232, -2.6854, -0.0707, 2.8499, 1.5874]
    T-shape init: x=0.03, y=0, z=0.121, quat=1 0 0 0 (upright)
  -->
  <keyframe>
    <!--
      qpos layout (14 values):
        [0:7]  tshape freejoint: x y z qw qx qy qz
        [7:14] joint1..joint7 (revolute)
    -->
    <key name="home"
      qpos="0.03 0 0.121 1 0 0 0
            0.6127 0.1663 0.1232 -2.6854 -0.0707 2.8499 1.5874"
      ctrl="0.6127 0.1663 0.1232 -2.6854 -0.0707 2.8499 1.5874"/>
  </keyframe>
</mujoco>
